#!/usr/bin/env bash
# meeting-hive CLI wrapper — activates the package's venv and invokes it.
#
# After install.sh runs, this wrapper is symlinked into ~/bin/ (or wherever the
# user chose). It bootstraps the venv on first run so manual intervention is
# not needed.

set -euo pipefail

# Resolve the repo directory from this script's real path (follows symlinks).
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c "import os, sys; print(os.path.realpath(sys.argv[1]))" "${BASH_SOURCE[0]}")"
REPO="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

VENV="$REPO/.venv"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/meeting-hive"
SECRETS="$CONFIG_DIR/secrets.env"

# Load secrets (ANTHROPIC_API_KEY, etc.)
if [ -f "$SECRETS" ]; then
  # shellcheck disable=SC1090
  set -a; source "$SECRETS"; set +a
fi

# Bootstrap venv on first run.
if [ ! -d "$VENV" ]; then
  echo "[meeting-hive] bootstrapping venv at $VENV" >&2
  if command -v python3.13 >/dev/null 2>&1; then
    PYTHON=python3.13
  elif command -v python3.12 >/dev/null 2>&1; then
    PYTHON=python3.12
  elif command -v python3.11 >/dev/null 2>&1; then
    PYTHON=python3.11
  else
    echo "[meeting-hive] ERROR: need Python >= 3.11 (python3.11 / 3.12 / 3.13)" >&2
    exit 1
  fi
  "$PYTHON" -m venv "$VENV"
  "$VENV/bin/pip" install --quiet --upgrade pip
  "$VENV/bin/pip" install --quiet -e "$REPO"
fi

exec "$VENV/bin/python" -m meeting_hive "$@"
